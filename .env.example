# ===========================================
# Loopforge Environment Configuration
# ===========================================
# Copy this file to .env.local for development
# or .env for Docker deployment

# ===========================================
# Authentication (Required)
# ===========================================
# GitHub OAuth App credentials
#
# HOW TO CREATE A GITHUB OAUTH APP:
# 1. Go to https://github.com/settings/developers
# 2. Click "New OAuth App"
# 3. Fill in the following:
#    - Application name: Loopforge
#    - Homepage URL: http://localhost:3000 (or your production URL)
#    - Authorization callback URL: http://localhost:3000/api/auth/callback/github
# 4. Click "Register application"
# 5. Copy the Client ID below
# 6. Click "Generate a new client secret" and copy it below
#
# IMPORTANT: For production, replace localhost:3000 with your actual domain
#
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# NextAuth.js secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret

# NextAuth.js URL (your app's URL - must match GitHub OAuth callback URL)
NEXTAUTH_URL=http://localhost:3000

# ===========================================
# Encryption (Required)
# ===========================================
# Encryption key for sensitive data (API keys, GitHub tokens)
# Generate with: openssl rand -hex 32
# This produces a 64-character hex string (32 bytes)
ENCRYPTION_KEY=your_64_character_hex_string

# ===========================================
# Database (Required for PostgreSQL)
# ===========================================
# PostgreSQL connection URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/loopforge

# For Docker deployment, the URL will be:
# DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/loopforge

# PostgreSQL password (for Docker deployment)
POSTGRES_PASSWORD=postgres

# ===========================================
# Redis (Optional - has defaults)
# ===========================================
# Redis connection URL for BullMQ job queue
REDIS_URL=redis://localhost:6379

# ===========================================
# Worker Configuration (Optional)
# ===========================================
# Directory where repositories are cloned for execution
# REPOS_DIR=/app/repos

# ===========================================
# AI Provider
# ===========================================
# For BYOK users: API key is configured per-user in the app
# and stored encrypted in the database.
# Get your key at: https://console.anthropic.com

# For Managed users: App's shared Anthropic API key
# This key is used for users who pay via Stripe subscription
APP_ANTHROPIC_API_KEY=your_app_anthropic_api_key

# ===========================================
# Stripe (Required for Managed billing)
# ===========================================
# Stripe API keys - get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Webhook Secret - get when creating webhook endpoint
# Create webhook at: https://dashboard.stripe.com/webhooks
# Events to listen for: customer.subscription.created, customer.subscription.updated,
#                       customer.subscription.deleted, invoice.paid, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs - create products/prices in Stripe Dashboard
# Create at: https://dashboard.stripe.com/products
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly_id
STRIPE_PRICE_TEAM_MONTHLY=price_team_monthly_id
STRIPE_PRICE_TEAM_YEARLY=price_team_yearly_id

# ===========================================
# Quick Setup Commands
# ===========================================
# Generate NEXTAUTH_SECRET:
#   openssl rand -base64 32
#
# Generate ENCRYPTION_KEY:
#   openssl rand -hex 32
#
# For Docker deployment:
#   1. Copy this file to .env
#   2. Fill in all required values
#   3. Run: docker compose up -d
#   4. Visit http://localhost:3000/setup if OAuth not configured
