# ===========================================
# Loopforge Studio Environment Configuration
# ===========================================
#
# QUICK START:
#   1. Copy this file: cp .env.example .env
#   2. Add your GitHub OAuth credentials (see below)
#   3. Run: ./scripts/init-secrets.sh  (auto-generates secrets)
#   4. Run: docker compose up
#
# ===========================================

# ===========================================
# GitHub OAuth (REQUIRED)
# ===========================================
# You MUST create your OWN GitHub OAuth App to use Loopforge Studio.
#
# ⚠️  SECURITY WARNING:
#     - NEVER commit your Client Secret to version control
#     - NEVER share your Client Secret publicly
#     - Each user/installation must create their own OAuth App
#
# HOW TO CREATE A GITHUB OAUTH APP:
#   1. Go to: https://github.com/settings/developers
#   2. Click "New OAuth App"
#   3. Fill in:
#      - Application name: Loopforge Studio (or any name)
#      - Homepage URL: http://localhost:3000
#      - Authorization callback URL: http://localhost:3000/api/auth/callback/github
#   4. Click "Register application"
#   5. Copy the Client ID below
#   6. Click "Generate a new client secret" and copy it below
#
# For network access: Replace localhost:3000 with your machine's IP or hostname
#
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ===========================================
# Secrets (Auto-generated)
# ===========================================
# These are auto-generated by ./scripts/init-secrets.sh
# You can also generate them manually:
#   NEXTAUTH_SECRET: openssl rand -base64 32
#   ENCRYPTION_KEY:  openssl rand -hex 32
#
# Leave blank to auto-generate on first run:
NEXTAUTH_SECRET=
ENCRYPTION_KEY=

# ===========================================
# Database (Has Defaults)
# ===========================================
# Loopforge uses a dedicated 'loopforge' PostgreSQL user (not 'postgres')
# This user is auto-created by scripts/init-db.sql on first Docker startup
#
# For HYBRID development (local web server + Docker services):
DATABASE_URL=postgresql://loopforge:loopforge@localhost:5432/loopforge
#
# For FULL DOCKER development (everything in Docker):
# DATABASE_URL=postgresql://loopforge:loopforge@postgres:5432/loopforge
#
# PostgreSQL superuser password (used by 'postgres' admin user):
# POSTGRES_PASSWORD=postgres

# ===========================================
# Redis (Has Defaults)
# ===========================================
# Default: Uses Docker Redis container
#
# For HYBRID development (local web server + Docker services):
REDIS_URL=redis://localhost:6379
#
# For FULL DOCKER development (everything in Docker):
# REDIS_URL=redis://redis:6379

# ===========================================
# Application URL (Has Default)
# ===========================================
# Default: http://localhost:3000
# Change if accessing from other devices on your network
#
# NEXTAUTH_URL=http://localhost:3000
# PORT=3000

# ===========================================
# Ralph Loop Reliability Features (Optional)
# ===========================================
# Enable progressive rollout of reliability improvements.
# Reliability features are ENABLED by default (as of 2026-01-29).
# Disable by setting environment variable to false if needed.
#
# Enable multi-signal stuck detection (replaces simple error counting)
# ENABLE_STUCK_DETECTOR=true
#
# Enable 4-tier progressive error recovery system
# ENABLE_RECOVERY_STRATEGIES=true
#
# Enable completion validation with plan matching
# ENABLE_COMPLETION_VALIDATION=true
#
# Enable enhanced file extraction with progressive strategies
# ENABLE_ENHANCED_EXTRACTION=true
#
# Enable test gate enforcement (blocks PRs on critical test failures)
# ENABLE_TEST_GATES=true
#
# Enable A/B testing framework UI (experiments page and navigation)
# ENABLE_AB_TESTING=true
#
# Enable automatic PR creation after successful execution (default: false)
# When enabled, PRs are created automatically but NOT merged (manual review required)
# ENABLE_AUTO_PR_CREATION=false

# ===========================================
# Stripe (Optional - for SaaS billing)
# ===========================================
# Required only if you want to enable subscription billing.
#
# SETUP STEPS:
#   1. Get API keys from: https://dashboard.stripe.com/apikeys
#   2. Run: npm run stripe:setup (creates products and prices)
#   3. Create webhook at: https://dashboard.stripe.com/webhooks
#      - Endpoint: https://yourdomain.com/api/stripe/webhook
#      - Events: checkout.session.completed, customer.subscription.created,
#                customer.subscription.updated, customer.subscription.deleted,
#                invoice.payment_failed
#   4. Copy the webhook signing secret to STRIPE_WEBHOOK_SECRET
#   5. Run: npm run db:seed (seeds plans with Stripe price IDs)
#
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...  # REQUIRED for production webhooks
#
# Price IDs (auto-generated by npm run stripe:setup):
# STRIPE_PRICE_PRO_MANAGED_MONTHLY=price_...
# STRIPE_PRICE_PRO_MANAGED_YEARLY=price_...
# STRIPE_PRICE_PRO_BYOK_MONTHLY=price_...
# STRIPE_PRICE_PRO_BYOK_YEARLY=price_...
# STRIPE_PRICE_TEAM_MANAGED_MONTHLY=price_...
# STRIPE_PRICE_TEAM_MANAGED_YEARLY=price_...
# STRIPE_PRICE_TEAM_BYOK_MONTHLY=price_...
# STRIPE_PRICE_TEAM_BYOK_YEARLY=price_...
