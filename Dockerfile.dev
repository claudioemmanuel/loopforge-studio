# syntax=docker/dockerfile:1

# ============================================
# Development Dockerfile with hot reload
# ============================================
FROM node:22-alpine

# Install dependencies needed for native modules, git, and postgresql-client
RUN apk add --no-cache libc6-compat python3 make g++ git postgresql-client

WORKDIR /app

# Copy package files first for better caching
COPY package.json package-lock.json* ./

# Install all dependencies (including devDependencies)
# Using npm install instead of npm ci for development flexibility
RUN --mount=type=cache,target=/root/.npm \
    npm install

# Copy entrypoint script
COPY scripts/docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Source code is mounted as volume for hot reload
# No COPY of source files needed

ENV NODE_ENV=development

EXPOSE 3000

# Start with entrypoint (runs migrations/seed before app)
ENTRYPOINT ["docker-entrypoint.sh"]
CMD ["npm", "run", "dev"]
