{
  "name": "loopforge-studio",
  "version": "0.1.0",
  "description": "The Visual GUI for AI-Powered Coding - self-hosted web interface for autonomous AI coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/claudioemmanuel/loopforge-studio.git"
  },
  "homepage": "https://github.com/claudioemmanuel/loopforge-studio",
  "author": "Loopforge Studio Contributors",
  "keywords": [
    "ai",
    "coding",
    "automation",
    "claude",
    "nextjs",
    "self-hosted"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:docker": "docker compose -f docker-compose.dev.yml up",
    "dev:docker:build": "docker compose -f docker-compose.dev.yml up --build",
    "dev:docker:down": "docker compose -f docker-compose.dev.yml down",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx lib/db/seed.ts",
    "worker": "tsx workers/execution-worker.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "bullmq": "^5.67.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.563.0",
    "next": "^16.1.4",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4.6",
    "openai": "^6.16.0",
    "pg": "^8.17.2",
    "pino": "^10.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "simple-git": "^3.27.0",
    "tailwind-merge": "^3.4.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.5.14",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
