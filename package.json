{
  "name": "loopforge-studio",
  "version": "0.1.0",
  "description": "The Visual GUI for AI-Powered Coding - self-hosted web interface for autonomous AI coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/claudioemmanuel/loopforge-studio.git"
  },
  "homepage": "https://github.com/claudioemmanuel/loopforge-studio",
  "author": "Loopforge Studio Contributors",
  "keywords": [
    "ai",
    "coding",
    "automation",
    "claude",
    "nextjs",
    "self-hosted"
  ],
  "scripts": {
    "predev": "node scripts/prep-dev.js",
    "dev": "next dev",
    "dev:skip-migrate": "next dev",
    "dev:turbo": "TURBOPACK=1 next dev --turbo",
    "dev:docker": "docker compose -f docker-compose.dev.yml up",
    "dev:docker:build": "docker compose -f docker-compose.dev.yml up --build",
    "dev:docker:down": "docker compose -f docker-compose.dev.yml down",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "node scripts/db-generate-wrapper.js",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx lib/db/seed.ts",
    "worker": "tsx workers/execution-worker.ts",
    "analyze": "ANALYZE=true next build",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.21.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@swc/helpers": "0.5.18",
    "@types/dagre": "^0.7.53",
    "@types/diff": "^7.0.2",
    "@types/express": "^5.0.6",
    "@xyflow/react": "^12.10.0",
    "bullmq": "^5.40.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "diff": "^8.0.3",
    "drizzle-orm": "^0.38.4",
    "express": "^5.2.1",
    "figma-squircle": "^1.1.0",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.473.0",
    "next": "^15.1.6",
    "next-auth": "^5.0.0-beta.25",
    "next-intl": "^4.8.1",
    "next-themes": "^0.4.6",
    "openai": "^4.104.0",
    "pg": "^8.17.2",
    "pino": "^10.3.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.6.0",
    "roughjs": "^4.6.6",
    "sharp": "^0.34.5",
    "simple-git": "^3.27.0",
    "tailwind-merge": "^2.6.0",
    "web-vitals": "^5.1.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^3.0.4",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.2",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
