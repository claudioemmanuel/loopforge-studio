#!/usr/bin/env sh

# Check for common secret patterns in files being pushed
FILES=$(git diff --name-only origin/main...HEAD 2>/dev/null | grep -v '\.husky/')
if [ -n "$FILES" ]; then
  if echo "$FILES" | xargs grep -l -E "(sk-ant-|ghp_|gho_|GITHUB_CLIENT_SECRET=.{10,})" 2>/dev/null; then
    echo "ERROR: Potential secrets detected in pushed files!"
    exit 1
  fi
fi
